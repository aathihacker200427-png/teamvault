# Database
POSTGRES_USER=teamvault
POSTGRES_PASSWORD=teamvault_secret
POSTGRES_DB=teamvault

# Backend
DATABASE_URL=postgresql://teamvault:teamvault_secret@postgres:5432/teamvault
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRATION_HOURS=24
CORS_ORIGIN=http://localhost
RUST_LOG=info

# SFU
SFU_URL=http://sfu:8080
SFU_SECRET=sfu-shared-secret
SFU_WEBRTC_PORT_MIN=50000
SFU_WEBRTC_PORT_MAX=50200

# Frontend
VITE_API_URL=http://localhost/api/v1
VITE_WS_URL=ws://localhost/api/v1/ws

# TURN Server
TURN_REALM=teamvault.local
TURN_USER=turnuser
TURN_PASSWORD=turnpassword
